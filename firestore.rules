rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidDiscussionShape(data) {
      return data.keys().hasAll(['subgenreSlug', 'interestSlug', 'title', 'body', 'hasSpoilers', 'authorId', 'authorName'])
        && data.subgenreSlug is string
        && data.interestSlug is string
        && data.title is string
        && data.title.size() >= 3
        && data.title.size() <= 120
        && data.body is string
        && data.body.size() >= 1
        && data.body.size() <= 5000
        && data.hasSpoilers is bool
        && data.authorId == request.auth.uid
        && data.authorName is string
        && data.authorName.size() >= 3
        && data.authorName.size() <= 50;
    }

    function isValidCommentShape(data) {
      return data.keys().hasAll(['body', 'hasSpoilers', 'authorId', 'authorName'])
        && data.body is string
        && data.body.size() >= 1
        && data.body.size() <= 2000
        && data.hasSpoilers is bool
        && data.authorId == request.auth.uid
        && data.authorName is string
        && data.authorName.size() >= 3
        && data.authorName.size() <= 50;
    }

    function isValidProfileShape(data) {
      return data.keys().hasAll(['displayName', 'interests', 'subgenres', 'perspectives'])
        && data.displayName is string
        && data.displayName.size() >= 3
        && data.displayName.size() <= 50;
    }

    // users: solo el dueño lee y escribe sus datos básicos
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // profiles: lectura para autenticados (preparado para discovery futuro),
    // escritura solo del dueño
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidProfileShape(request.resource.data);
      allow update: if isOwner(userId) && isValidProfileShape(request.resource.data);
      allow delete: if false;
    }

    // Catálogos: lectura para autenticados, escritura solo desde scripts admin
    match /interests/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /subgenres/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /perspectives/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Discusiones de comunidad: lectura para autenticados, creación con forma
    // válida y autor = uid. Sin edición ni borrado en este sprint.
    match /discussions/{discussionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidDiscussionShape(request.resource.data);
      allow update: if false;
      allow delete: if false;

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidCommentShape(request.resource.data);
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
